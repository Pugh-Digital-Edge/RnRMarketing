---
import client from "@data/client.json";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import CustomChat from "@components/CustomChat.astro";
import "@styles/root.less";
import "@styles/dark.less";

const { description, title, preloadedImage, dateModified } = Astro.props;
// Keep one editorial freshness date for pages without frontmatter. Page-specific
// resource dates override this through the dateModified prop.
const effectiveDateModified = dateModified ?? '2026-07-16';
const canonicalUrl = `https://${client.domain}${Astro.url.pathname}`;
const markdownUrl = `${Astro.url.pathname}index.md`;
const fullBrandSuffix = ` | ${client.name}`;
const shortBrandSuffix = ' | R&R Marketing';
const titleAlreadyNamesBrand = title.includes(client.name);
const titleAlreadyHasQualifier = title.includes('|');
const titleIsSelfContained = title.length >= 55;
const chosenTitleSuffix = titleAlreadyNamesBrand || titleAlreadyHasQualifier || titleIsSelfContained
    ? ''
    : `${title}${fullBrandSuffix}`.length <= 70 ? fullBrandSuffix : shortBrandSuffix;
const titleLimit = 70 - chosenTitleSuffix.length;
const shortenedTitle = title.length > titleLimit
    ? title.slice(0, titleLimit).replace(/\s+\S*$/, '').replace(/(?:\s+(?:and|for|with|the)|\s*&|[|,:;-]+)$/i, '').trim()
    : title;
const metadataTitle = `${shortenedTitle}${chosenTitleSuffix}`;
const descriptionSuffix = ' Explore SEO, PPC, web design, and lead tracking built specifically for restoration companies.';
const expandedDescription = description.length < 120
    ? `${description.trim().replace(/[.!?]?$/, '.')} ${descriptionSuffix}`
    : description.trim();
const metadataDescription = expandedDescription.length > 160
    ? `${expandedDescription.slice(0, 159).replace(/\s+\S*$/, '').replace(/[,:;-]+$/, '').trim()}.`
    : expandedDescription;

---
<!-- A fully fleshed-out <head>, dynamically changing based on client.json and the page front matter -->
<html lang="en">
        <head>
            <!-- Standard meta tags -->
            <meta charset="UTF-8">
            <meta http-equiv="X-UA-Compatible" content="IE=edge">
            <meta name="viewport" content="width=device-width, initial-scale=1.0">
            <meta name="description" content={metadataDescription}>
            <meta name="author" content="Matt Pugh">
            <link rel="canonical" href={canonicalUrl}>
            <link rel="alternate" type="text/markdown" href={markdownUrl} title={`${title} in Markdown`}>
            <link rel="alternate" type="text/plain" href="/llms.txt">
            <link rel="alternate" type="text/plain" href="/llms-full.txt">

            <!-- WebPage node ties each URL to the site + business entity and marks the
                 primary content region, giving AI crawlers a clear extraction target. -->
            <script type="application/ld+json" is:inline set:html={JSON.stringify({
                "@context": "https://schema.org",
                "@type": "WebPage",
                "@id": `https://${client.domain}${Astro.url.pathname}#webpage`,
                "url": `https://${client.domain}${Astro.url.pathname}`,
                "name": title,
                "alternativeHeadline": title,
                "description": metadataDescription,
                "inLanguage": "en-US",
                "dateModified": effectiveDateModified,
                "isPartOf": { "@id": "https://remediationrestorationmarketing.com/#website" },
                "about": { "@id": "https://remediationrestorationmarketing.com/#localbusiness" },
                "primaryImageOfPage": {
                    "@type": "ImageObject",
                    "url": "https://remediationrestorationmarketing.com/assets/images/logo-small.jpg"
                },
                "speakable": {
                    "@type": "SpeakableSpecification",
                    "cssSelector": ["h1", ".cs-title", ".cs-text"]
                }
            })} />


            <script type="application/ld+json" is:inline>
                {
                    "@context": "https://schema.org",
                    "@type": "LocalBusiness",
                    "name": "Remediation & Restoration Marketing",
                    "image": "https://remediationrestorationmarketing.com/assets/images/logo-small.jpg",
                    "@id": "https://remediationrestorationmarketing.com/#localbusiness",
                    "url": "https://remediationrestorationmarketing.com",
                    "telephone": "17174201766",
                    "email": "matt@remediationrestorationmarketing.com",
                    "priceRange": "$$",
                    "openingHours": "Mo-Fr 09:00-22:00",
                    "address": {
                        "@type": "PostalAddress",
                        "streetAddress": "1000 Carlisle St, STE 1625, Room 2",
                        "addressLocality": "Hanover",
                        "addressRegion": "PA",
                        "postalCode": "17331",
                        "addressCountry": "US"
                    },
                    "sameAs": [
                        "https://www.facebook.com/remediationrestorationmarketing",
                        "https://www.youtube.com/@RandR_Marketing",
                        "https://www.instagram.com/randr.marketing/",
                        "https://remediationrestorationmarketing.com"
                    ],
                    "founder": {
                        "@type": "Person",
                        "@id": "https://remediationrestorationmarketing.com/about/#matt-pugh",
                        "name": "Matt Pugh",
                        "jobTitle": "Founder and Restoration Marketing Specialist"
                    },
                    "geo": {
                        "@type": "GeoCoordinates",
                        "latitude": 39.8172159,
                        "longitude": -76.99499730000001
                    },
                    "openingHoursSpecification": {
                        "@type": "OpeningHoursSpecification",
                        "dayOfWeek": [
                            "Monday",
                            "Tuesday",
                            "Wednesday",
                            "Thursday",
                            "Friday"
                        ],
                        "opens": "09:00",
                        "closes": "22:00"
                    }
                }
            </script>

                <script type="application/ld+json" is:inline>
                {
                    "@context": "https://schema.org",
                    "@type": "Organization",
                    "name": "Remediation & Restoration Marketing",
                    "url": "https://remediationrestorationmarketing.com",
                    "logo": "https://remediationrestorationmarketing.com/assets/images/logo-small.jpg",
                    "image": "https://remediationrestorationmarketing.com/assets/images/logo-small.jpg",
                    "description": "Specialized marketing agency helping restoration companies generate more emergency service leads through SEO, PPC, web design, and digital marketing.",
                    "contactPoint": {
                    "@type": "ContactPoint",
                    "telephone": "+1-717-420-1766",
                    "email": "matt@remediationrestorationmarketing.com",
                    "contactType": "sales",
                    "areaServed": "US",
                    "availableLanguage": "English"
                    },
                    "sameAs": [
                    "https://www.facebook.com/remediationrestorationmarketing",
                    "https://www.youtube.com/@RandR_Marketing",
                    "https://www.instagram.com/randr.marketing/"
                    ],
                    "areaServed": {
                    "@type": "Country",
                    "name": "United States"
                    },
                    "brand": {
                    "@type": "Brand",
                    "name": "Remediation & Restoration Marketing",
                    "slogan": "Marketing Solutions for Restoration Companies"
                    },
                    "knowsAbout": [
                    "Water Damage Restoration Marketing",
                    "Fire Damage Restoration Marketing",
                    "Mold Remediation Marketing",
                    "Commercial Restoration Marketing",
                    "Sewage Cleanup Marketing",
                    "Biohazard Cleanup Restoration Marketing",
                    "Roof Damage Restoration Restoration Marketing"
                    ],
                    "foundingDate": "2024",
                    "founder": {
                        "@type": "Person",
                        "@id": "https://remediationrestorationmarketing.com/about/#matt-pugh",
                        "name": "Matt Pugh",
                        "url": "https://remediationrestorationmarketing.com/about/#matt-pugh",
                        "jobTitle": "Founder and Restoration Marketing Specialist"
                    }
                }
                </script>
                <script type="application/ld+json" is:inline set:html={JSON.stringify({
                    "@context": "https://schema.org",
                    "@type": "Person",
                    "@id": "https://remediationrestorationmarketing.com/about/#matt-pugh",
                    "name": "Matt Pugh",
                    "url": "https://remediationrestorationmarketing.com/about/",
                    "jobTitle": "Founder and Restoration Marketing Specialist",
                    "knowsAbout": [
                        "Restoration Marketing",
                        "Search Engine Optimization",
                        "Pay Per Click Advertising",
                        "Lead Attribution",
                        "Conversion-focused Web Design"
                    ],
                    "worksFor": { "@id": "https://remediationrestorationmarketing.com/#localbusiness" }
                })} />
                <script type="application/ld+json" is:inline>
                {
                    "@context": "https://schema.org",
                    "@type": "WebSite",
                    "@id": "https://remediationrestorationmarketing.com/#website",
                    "url": "https://remediationrestorationmarketing.com",
                    "name": "Remediation & Restoration Marketing",
                    "description": "Specialized marketing agency helping restoration companies generate more emergency service leads through SEO, PPC, web design, and digital marketing.",
                    "publisher": {
                        "@id": "https://remediationrestorationmarketing.com/#localbusiness"
                    },
                    "potentialAction": {
                        "@type": "SearchAction",
                        "target": {
                            "@type": "EntryPoint",
                            "urlTemplate": "https://remediationrestorationmarketing.com/resources/?search={search_term_string}"
                        },
                        "query-input": "required name=search_term_string"
                    }
                }
                </script>
            <!-- Preloads the image passed as a prop -->
            <link rel="preload" href={preloadedImage.src} as="image" />
            <meta name="google-site-verification" content="Uhclxmf6JyErwpzjc2QhHZuENaQhwtR-TNMMiQVTT6o" />
            <!--Social Media Display-->
            <meta property="og:title" content={metadataTitle} />
            <meta property="og:description" content={metadataDescription} />
            <meta property="og:type" content="website" />
            <meta property="og:url" content={`https://${client.domain}${Astro.url.pathname}`} />
            <meta property="og:image" content="/assets/images/logo-small.jpg" />
            <meta property="og:image:secure_url" content="/assets/images/logo-small.jpg" />
            <link rel=sitemap href=/sitemap-index.xml>

            <!--Favicons-->
            <link rel="icon" type="image/png" href="/assets/favicons/favicon-96x96.png" sizes="96x96" />
            <link rel="icon" type="image/svg+xml" href="/assets/favicons/favicon.svg" />
            <link rel="shortcut icon" href="/assets/favicons/favicon.ico" />
            <link rel="apple-touch-icon" sizes="180x180" href="/assets/favicons/apple-touch-icon.png" />
            <link rel="manifest" href="/assets/favicons/site.webmanifest" />
            <meta name="msapplication-TileColor" content="#da532c">
            <meta name="theme-color" content="#ffffff">
         
            <!--For home page, use service keywords for the title, including location for SEO.
            Other pages should just include the page name.
            
            EXAMPLE:
            Home page - House Painting Contractors | Painters and Co. | TestCity, WA
            About Page - About us | Painters and Co.
            -->
            <title>
                {metadataTitle}
            </title>

            <!-- Decap CMS scripts -->
            {Astro.url.pathname === "/" &&
                <script defer src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
                <script defer>
                    if (window.netlifyIdentity) {
                        window
                            .netlifyIdentity
                            .on('init', (user) => {
                                if (!user) {
                                    window
                                        .netlifyIdentity
                                        .on('login', () => {
                                            document.location.href = '/admin/';
                                        });
                                }
                            });
                    }
                </script>
            }

            <!-- Sitewide Scripts -->
            <script src="../assets/js/nav.js"></script>
             <!-- Google tag (gtag.js) -->
            <script async src="https://www.googletagmanager.com/gtag/js?id=G-4K4H62DJ77"></script>
            <script is:inline>
                window.dataLayer = window.dataLayer || [];
                window.gtag = function gtag(){dataLayer.push(arguments);}
                gtag('js', new Date());

                gtag('config', 'G-4K4H62DJ77');
            </script>
            <script is:inline>
                document.addEventListener('click', (event) => {
                    if (!(event.target instanceof Element)) {
                        return;
                    }

                    const phoneLink = event.target.closest('a[href^="tel:"]');

                    if (!phoneLink || typeof window.gtag !== 'function') {
                        return;
                    }

                    window.gtag('event', 'phone_call_click', {
                        event_category: 'engagement',
                        event_label: phoneLink.textContent.trim(),
                        link_url: phoneLink.href,
                        link_text: phoneLink.textContent.trim(),
                        page_location: window.location.href,
                        transport_type: 'beacon',
                    });
                });
            </script>
        
        </head>
        <body>
            <!--Screen reader skip main nav-->
            <a class="skip" aria-label="skip to main content" href="#main">Click To Skip To Main Content</a>
    
            <Header />
            <main id="main">
                <slot/>
            </main>
            <Footer />
            <CustomChat />
        </body>
        <noscript>
            <!-- Matomo Image Tracker-->
            <img referrerpolicy="no-referrer-when-downgrade" src="https://remediationrestorationmarketing.matomo.cloud/matomo.php?idsite=1&amp;rec=1" style="border:0" alt="" />
            <!-- End Matomo -->
        </noscript>
</html>
